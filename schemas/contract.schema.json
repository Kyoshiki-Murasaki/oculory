{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oculory.dev/schemas/contract.schema.json",
  "title": "Oculory contract",
  "description": "Editable, replayable assertions approved for one Oculory task.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "task", "assertions"],
  "properties": {
    "version": {
      "const": "oculory-contract-v1"
    },
    "task": {
      "$ref": "#/$defs/id"
    },
    "tolerance": {
      "$ref": "#/$defs/tolerance",
      "default": {
        "runs": 12,
        "min_pass": 10
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 512,
      "items": {
        "$ref": "#/$defs/assertion"
      },
      "$comment": "Assertion IDs must be unique. The maintained loader enforces this cross-item constraint."
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{0,63}$"
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runs", "min_pass"],
      "properties": {
        "runs": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "min_pass": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        }
      },
      "$comment": "min_pass must be less than or equal to runs. The maintained loader enforces this cross-field constraint."
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "selector", "operator", "expected", "evaluation"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "target": {
          "$ref": "#/$defs/id"
        },
        "selector": {
          "type": "object",
          "description": "Adapter-specific selector interpreted by the assertion's target adapter."
        },
        "operator": {
          "enum": ["exists", "equals", "count", "unchanged", "none", "subset"]
        },
        "expected": {},
        "evaluation": {
          "enum": ["exact", "subset", "ignore"]
        }
      }
    }
  }
}
