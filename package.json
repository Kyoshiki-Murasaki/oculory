{
  "name": "oculory",
  "version": "0.1.0",
  "description": "Trace-derived, deterministic-first regression testing for MCP servers",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kyoshiki-Murasaki/oculory.git"
  },
  "homepage": "https://github.com/Kyoshiki-Murasaki/oculory#readme",
  "bugs": {
    "url": "https://github.com/Kyoshiki-Murasaki/oculory/issues"
  },
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.13"
  },
  "bin": {
    "oculory": "./bin/oculory",
    "oculory-demo-agent": "./dist/src/mlp/scripted-agent-main.js",
    "oculory-demo-server": "./dist/src/mlp/demo-server-main.js",
    "oculory-demo-fixture": "./dist/src/mlp/demo-fixture-main.js"
  },
  "exports": {
    "./adapters": "./dist/src/mlp/adapters/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --experimental-sqlite --no-warnings --test \"dist/test/**/*.test.js\" test/launcher-and-version.test.mjs test/package-policy.test.mjs",
    "diagnose:git-fixture": "npm run build && node dist/test/support/diagnose-git-fixture-determinism.js",
    "test:external-git-spike": "npm run build && node dist/test/support/run-git-mcp-spike.js",
    "test:external-git-formal-gate-b": "npm run build && node dist/test/support/run-git-mcp-formal-gate-b.js",
    "test:external-git-formal-gate-b-attempt": "npm run build && node dist/test/support/run-git-mcp-formal-gate-b.js",
    "test:external-git-gate-c": "npm run build && node dist/test/support/run-git-mcp-gate-c.js",
    "test:git-gate-d": "npm run build && node dist/test/support/run-git-mcp-gate-d.js",
    "test:external-git-gate-e1": "npm run build && node dist/test/support/run-git-mcp-gate-e1.js",
    "compile:external-git-gate-e2-suite": "npm run build && node dist/test/support/compile-git-gate-e2-suite.js",
    "write:external-git-gate-e2-registry": "npm run build && node dist/test/support/write-git-gate-e2-registry.js",
    "test:external-git-gate-e2": "npm run build && node dist/test/support/run-git-mcp-gate-e2.js",
    "validate:gate-f-authorization": "npm run build && node dist/test/support/validate-gate-f-authorization.js authorizations/gate-f1-authorization-template.json",
    "test:gate-f0": "npm run build && node --experimental-sqlite --no-warnings --test \"dist/test/gate-f0*.test.js\"",
    "test:external-git-gate-f0": "npm run build && node dist/test/support/run-git-mcp-gate-f0.js",
    "validate:phase6-evidence-index": "npm run build && node dist/test/support/validate-phase6-evidence-index.js docs/evidence/phase6-external-git-evidence-index-v1.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "experiment": "npm run build && node bin/oculory experiment",
    "experiment:filesystem": "npm run build && node bin/oculory fs-experiment",
    "experiment:issue-tracker": "npm run build && node bin/oculory issue-experiment",
    "prepack": "npm run build",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:action": "npm run build && node scripts/verify-action.mjs",
    "pilot:doctor": "npm run build && node dist/pilot/src/cli.js doctor",
    "pilot:run": "npm run build && node dist/pilot/src/cli.js run",
    "pilot:verify-report": "npm run build && node dist/pilot/src/cli.js verify-report",
    "pilot:smoke": "npm run build && node dist/pilot/src/cli.js smoke"
  },
  "dependencies": {
    "pg": "^8.22.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.0"
  },
  "files": [
    "dist/src",
    "bin",
    "schemas",
    "fixtures/demo",
    "fixtures/seed.json",
    "README.md",
    "LICENSE"
  ]
}
